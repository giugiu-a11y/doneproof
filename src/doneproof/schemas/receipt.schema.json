{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doneproof.dev/schemas/receipt.schema.json",
  "title": "DoneProof Receipt",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "task",
    "status",
    "summary",
    "changed_files",
    "commands",
    "evidence",
    "risks"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "task": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["awaiting_review", "blocked", "failed"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["cmd", "status"],
        "properties": {
          "cmd": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped"]
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "value"],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
